# ---- Claude / Anthropic (server-side only; never expose to the client) ----
# Powers BOTH the company analysis generator (POST /api/companies/:ticker/generate-analysis)
# AND the built-in AI research chat (POST /api/ai/chat). If unset, both gracefully
# fall back to a structured mock flagged generatedBy:'mock'.
# ----
# Priority 1: standard production env vars.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Optional. Defaults to https://api.anthropic.com when ANTHROPIC_API_KEY is set.
ANTHROPIC_BASE_URL=https://api.anthropic.com
# Optional model override. Defaults to claude-sonnet-4-20250514.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Priority 2 (optional): Perplexity secure credential proxy for api.anthropic.com.
# CUSTOM_CRED_API_ANTHROPIC_COM_URL=https://...
# CUSTOM_CRED_API_ANTHROPIC_COM_TOKEN=...

# ---- Runtime ----
NODE_ENV=production
# Railway sets PORT automatically; the server falls back to 5000 if unset.
# PORT=5000
